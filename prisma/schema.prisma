generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Party {
  id          Int      @id @default(autoincrement())
  honoreeName String   @map("honoree_name")
  age         Int
  partyDate   DateTime @map("party_date") @db.Date
  message     String?
  gifts       Gift[]

  @@map("party")
}

model Gift {
  id             Int            @id @default(autoincrement())
  party          Party          @relation(fields: [partyId], references: [id])
  partyId        Int            @map("party_id")
  name           String
  description    String?
  category       String
  image          String         @default("")
  storeLink      String         @default("") @map("store_link")
  suggestedValue Decimal?       @map("suggested_value") @db.Decimal(10, 2)
  pixLink        String         @default("") @map("pix_link")
  contributions  Contribution[]

  @@map("gifts")
}

model Contribution {
  id        Int      @id @default(autoincrement())
  gift      Gift     @relation(fields: [giftId], references: [id])
  giftId    Int      @map("gift_id")
  names     String[] @map("names")
  email     String?  @map("email")
  message   String?  @map("message")
  status    String   @default("pendente")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("contributions")
}